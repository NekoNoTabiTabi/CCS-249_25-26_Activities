[32m+[m[32m# HELPER: Tokeniser[m
[32m+[m[32mdef tokenize(text: str) -> list[str]:[m
[32m+[m[32m    """Lowercase and extract alphabetic tokens only."""[m
[32m+[m[32m    return re.findall(r"[a-z]+", text.lower())[m
[32m+[m
[32m+[m
[32m+[m
[32m+[m[32m# 1.) A. GENERATE BAG OF WORDS (for word frequency)[m
[32m+[m
[32m+[m[32mdef generate_bag_of_words(data: list[tuple[str, str]]) -> dict:[m
[32m+[m[32m    """[m
[32m+[m[32m    Returns:[m
[32m+[m[32m        bow  – {class_label: {word: count}}[m
[32m+[m[32m    """[m
[32m+[m[32m    bow = defaultdict(lambda: defaultdict(int))[m
[32m+[m[32m    for text, label in data:[m
[32m+[m[32m        for word in tokenize(text):[m
[32m+[m[32m            bow[label][word] += 1[m
[32m+[m[32m    return bow[m
[32m+[m
[32m+[m
[32m+[m
[32m+[m[32m# 1.) B. Calculate the prior for the class HAM and SPAM[m
[32m+[m
[32m+[m[32mdef calculate_priors(data: list[tuple[str, str]]) -> dict:[m
[32m+[m[32m    """[m
[32m+[m[32m    Returns:[m
[32m+[m[32m        priors – {class_label: probability}[m
[32m+[m[32m    """[m
[32m+[m[32m    class_counts = defaultdict(int)[m
[32m+[m[32m    for _, label in data:[m
[32m+[m[32m        class_counts[label] += 1[m
[32m+[m[32m    total = len(data)[m
[32m+[m[32m    priors = {label: count / total for label, count in class_counts.items()}[m
[32m+[m[32m    return priors[m
[32m+[m
[32m+[m
[32m+[m[32m# 1.) C. Calculate the likelihood of the tokens in the vocabulary with respect to the class.[m
[32m+[m[32m# (with Laplace / add-1 smoothing)[m
[32m+[m[32m#    P(word | class) = (count(word, class) + 1)[m
[32m+[m[32m#                      / (total_words_in_class + vocab_size)[m
[32m+[m
[32m+[m[32mdef calculate_likelihoods([m
[32m+[m[32m    bow: dict,[m
[32m+[m[32m    vocabulary: set,[m
[32m+[m[32m    alpha: int = 1     # Laplace smoothing parameter[m
[32m+[m[32m) -> dict:[m
[32m+[m[32m    """[m
[32m+[m[32m    Returns:[m
[32m+[m[32m        likelihoods – {class_label: {word: P(word|class)}}[m
[32m+[m[32m    """[m
[32m+[m[32m    likelihoods = {}[m
[32m+[m[32m    vocab_size = len(vocabulary)[m
[32m+[m
[32m+[m[32m    for label, word_counts in bow.items():[m
[32m+[m[32m        total_words = sum(word_counts.values())[m
[32m+[m[32m        likelihoods[label] = {}[m
[32m+[m[32m        for word in vocabulary:[m
[32m+[m[32m            count = word_counts.get(word, 0)[m
[32m+[m[32m            likelihoods[label][word] = (count + alpha) / (total_words + vocab_size * alpha)[m
[32m+[m
[32m+[m[32m    return likelihoods[m
