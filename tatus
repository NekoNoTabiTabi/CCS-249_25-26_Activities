[32m+[m[32m# 1.) D. Determine the class of the following test sentence:  i. Limited offer, click here!   ii. Meeting at 2 PM with the manager.[m
[32m+[m[32m#    score(class) = log P(class) + Σ log P(word | class)[m
[32m+[m[32m#    (log-space to avoid underflow)[m
[32m+[m
[32m+[m[32mimport math[m
[32m+[m
[32m+[m[32mdef classify([m
[32m+[m[32m    text: str,[m
[32m+[m[32m    priors: dict,[m
[32m+[m[32m    likelihoods: dict,[m
[32m+[m[32m    vocabulary: set,[m
[32m+[m[32m    alpha: int = 1[m
[32m+[m[32m) -> tuple[str, dict]:[m
[32m+[m
[32m+[m[32m    tokens = tokenize(text)[m
[32m+[m[32m    scores = {}[m
[32m+[m
[32m+[m[32m    for label in priors:[m
[32m+[m[32m        log_score = math.log(priors[label])[m
[32m+[m[32m        total_words = sum(1 for w in likelihoods[label])   # |V|[m
[32m+[m[32m        for token in tokens:[m
[32m+[m[32m            if token in likelihoods[label]:[m
[32m+[m[32m                log_score += math.log(likelihoods[label][token])[m
[32m+[m[32m            # OOV tokens: already handled by Laplace — use smallest smoothed prob[m
[32m+[m[32m            # (Here every token in the test set is in the vocabulary for this dataset)[m
[32m+[m[32m        scores[label] = log_score[m
[32m+[m
[32m+[m[32m    predicted = max(scores, key=scores.get)[m
[32m+[m[32m    return predicted, scores[m
